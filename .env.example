# Root env for docker-compose.yml (production / VM — API only).
# Copy to .env and fill in with your VM's existing Postgres.

# Opção A (recomendada): variáveis separadas — senha CRUA, sem escapar @ # etc.
PGHOST=precatur_database
PGPORT=5432
PGUSER=postgre
PGPASSWORD=sua-senha-crua
PGDATABASE=database-precatur

# Opção B: URL única (escape @ -> %40, # -> %23 na senha). Use uma OU outra.
# DATABASE_URL=postgres://user:pass@host:5432/db
# Postgres com SSL: PGSSL=true (ou ?sslmode=require na URL)

PORT=8080

# Your Vercel frontend domain (comma-separated for multiple).
CORS_ORIGIN=https://seu-projeto.vercel.app

# Initial admin (created on first boot if no users exist). CHANGE THESE.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@precatur.com
ADMIN_PASSWORD=troque-esta-senha

# Long random string in production.
JWT_SECRET=troque-por-uma-string-aleatoria-longa
JWT_TTL=12h

# Create tables on boot (safe/idempotent).
MIGRATE_ON_START=true
# Seed demo leads. Set false in production (you'll use real data).
SEED_ON_START=false

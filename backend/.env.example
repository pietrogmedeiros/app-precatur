# Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sales

# HTTP port the API listens on
PORT=8080

# Comma-separated list of allowed origins (your Vercel domain in prod).
# Use * to allow any origin (dev only).
CORS_ORIGIN=http://localhost:3000

# --- Auth ---
# Initial admin, created on first boot if the users table is empty.
# CHANGE THESE IN PRODUCTION.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@precatur.com
ADMIN_PASSWORD=precatur
# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=dev-secret-change-me
# Token lifetime (e.g. 12h, 7d)
JWT_TTL=12h

# --- Metabase embedding ---
# Chave secreta de embedding do Metabase (Admin > Settings > Embedding).
# Usada apenas no servidor para assinar o JWT curto (10 min). NUNCA exponha no front.
METABASE_SECRET_KEY=
# URL da instância Metabase.
METABASE_INSTANCE_URL=https://precatur-metabase.ty9ddu.easypanel.host
# ID do dashboard a ser incorporado.
METABASE_DASHBOARD_ID=2

# Run migration on boot (idempotent). Recommended: true
MIGRATE_ON_START=true

# Seed the database with demo data if the leads table is empty. Set false in prod
# once you have real data.
SEED_ON_START=true
